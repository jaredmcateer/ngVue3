{
  "name": "@jaredcmateer/ngvue3-shared",
  "version": "0.0.0-development",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md,js,json,jsx,vue}\"",
    "changeset": "changeset",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "husky": "^9.1.0",
    "prettier": "^3.8.4",
    "turbo": "^2.9.18"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.13.0"
  },
  "packageManager": "pnpm@11.1.3"
}
