{
  "name": "@jaredmcateer/ngvue3",
  "description": "Use Vue 3 components in Angular 1.x",
  "license": "MIT",
  "files": [
    "dist",
    "package.json",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "javascript",
    "typescript",
    "migration",
    "vue",
    "vue3",
    "angular",
    "ng",
    "components",
    "ngvue",
    "ngvue3"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jaredmcateer/ngVue3.git"
  },
  "main": "./dist/main.mjs",
  "module": "./dist/main.mjs",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "import": "./dist/main.mjs",
      "require": "./dist/main.cjs"
    }
  },
  "version": "0.5.0",
  "scripts": {
    "clean": "rimraf dist/",
    "build": "pnpm run clean && vite build",
    "test": "jest --runInBand"
  },
  "devDependencies": {
    "@babel/core": "^7.17.10",
    "@babel/preset-env": "^7.17.10",
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-typescript": "^12.0.0",
    "@types/angular": "^1.8.4",
    "@types/angular-mocks": "^1.7.1",
    "@types/jest": "^29.5.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/test-utils": "^2.0.0-rc.21",
    "@vue/vue3-jest": "^29.2.6",
    "angular": "^1.8.3",
    "angular-mocks": "^1.8.3",
    "babel-core": "^7.0.0-bridge.0",
    "babel-jest": "^29.7.0",
    "config": "workspace:*",
    "global-jsdom": "^24.0.0",
    "jest": "^29.7.0",
    "jsdom": "^24.0.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.2.0",
    "tslib": "^2.8.0",
    "tsconfig": "workspace:*",
    "typescript": "^5.8.0",
    "vite": "^6.2.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.2.0"
  }
}
